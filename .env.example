# OpenAI API key used by the classifier agent (real LLM mode).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Chat model used for classification (cheap + fast is fine for this workflow).
OPENAI_CHAT_MODEL_ID=gpt-4o-mini

# Set to "true" to use a deterministic, keyword-based mock classifier instead
# of calling the OpenAI API. Useful for offline development and tests; the
# real agent mode (false/unset) is the intended homework run.
BUG_TRIAGE_MOCK_LLM=false
